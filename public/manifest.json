{
  "manifest_version": 3,
  "name": "One-click Tab Dedup/Group Manager",
  "version": "0.6.2",
  "description": "",
  "options_page": "index.html",
  "icons": {
    "192": "logo192.png",
    "512": "logo512.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab_dedup_manager@time_current.com",
      "update_url": "https://sea-lion-app-i977g.ondigitalocean.app/updates.json",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "action": {
    "default_icon": {
      "192": "logo192.png"
    },
    "default_title": "Tab Dedup Manager"
  },
  "background": {
    "scripts": [
      "assets/background.js"
    ],
    "type": "module"
  },
  "incognito": "split",
  "permissions": [
    "storage",
    "tabs",
    "tabGroups"
  ]
}