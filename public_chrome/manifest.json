{
  "manifest_version": 3,
  "name": "One-click Tab Dedup/Group Manager",
  "version": "0.5.18",
  "description": "",
  "options_ui": {
    "page": "index.html",
    "open_in_tab": true
  },
  "icons": {
    "192": "logo192.png",
    "512": "logo512.png"
  },
  "action": {
    "default_icon": {
      "192": "logo192.png"
    },
    "default_title": "Tab Dedup Manager"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "incognito": "spanning",
  "permissions": [
    "storage",
    "tabs",
    "tabGroups"
  ]
}