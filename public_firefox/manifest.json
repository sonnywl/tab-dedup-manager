{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "default_locale": "en",
  "version": "0.6.9",
  "description": "__MSG_appDescription__",
  "options_ui": {
    "page": "index.html",
    "open_in_tab": true
  },
  "icons": {
    "192": "logo192.png",
    "512": "logo512.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab_dedup_manager@time_current.com",
      "update_url": "https://sea-lion-app-i977g.ondigitalocean.app/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_icon": {
      "192": "logo192.png"
    },
    "default_title": "__MSG_actionTitle__"
  },
  "background": {
    "scripts": ["assets/background.js"],
    "type": "module"
  },
  "incognito": "split",
  "permissions": ["storage", "tabs", "tabGroups"]
}
